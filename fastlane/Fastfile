default_platform(:ios)

platform :ios do
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id:     ENV["ASC_KEY_ID"],
      issuer_id:  ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_PRIVATE_KEY"],
      in_house:   false,
    )

    # Provisioning profile otomatik alınır / oluşturulur
    sigh(
      api_key:        api_key,
      app_identifier: "app.realvirtuality.landlord",
      provisioning_name: "Hooder Distribution",
      force:          false,
      output_path:    "/tmp",
    )

    build_ios_app(
      project:        "ios/App/App.xcodeproj",
      scheme:         "App",
      configuration:  "Release",
      output_name:    "Hooder.ipa",
      export_method:  "app-store",
      export_options: {
        teamID: "SZF4T3P583",
        provisioningProfiles: {
          "app.realvirtuality.landlord" => "Hooder Distribution",
        },
      },
      xcargs:         "-clonedSourcePackagesDirPath /tmp/spm-cache",
    )

    upload_to_testflight(
      api_key:                         api_key,
      skip_waiting_for_build_processing: true,
      changelog:                       "PWA güncellendi — zoom ve platform iyileştirmeleri",
    )
  end
end
