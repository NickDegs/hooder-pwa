default_platform(:ios)

platform :ios do
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id:     ENV["ASC_KEY_ID"],
      issuer_id:  ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_PRIVATE_KEY"],
      in_house:   false,
    )

    # Provisioning profile otomatik alınır / oluşturulur.
    # NOT: sigh, mevcut bir app-store profilini (örn. "Hooder Distribution 178...")
    # bulup kullanabilir; bu yüzden çözülen GERÇEK profil adını yakalayıp her yerde
    # onu kullanırız — aksi halde xcodebuild "matching 'Hooder Distribution' yok" der.
    sigh(
      api_key:        api_key,
      app_identifier: "app.realvirtuality.landlord",
      provisioning_name: "Hooder Distribution",
      force:          true,   # push + applesignin capability'leriyle profili güncel üret
      output_path:    "/tmp",
    )
    profile_name = lane_context[SharedValues::SIGH_NAME]
    UI.message("Kullanılacak provisioning profili: #{profile_name}")

    update_code_signing_settings(
      use_automatic_signing: false,
      team_id:               "SZF4T3P583",
      code_sign_identity:    "iPhone Distribution",
      bundle_identifier:     "app.realvirtuality.landlord",
      profile_name:          profile_name,
      path:                  "ios/App/App.xcodeproj",
    )

    build_ios_app(
      project:        "ios/App/App.xcodeproj",
      scheme:         "App",
      configuration:  "Release",
      output_name:    "Hooder.ipa",
      export_method:  "app-store",
      export_options: {
        teamID: "SZF4T3P583",
        provisioningProfiles: {
          "app.realvirtuality.landlord" => profile_name,
        },
        signingStyle: "manual",
      },
      xcargs: "-clonedSourcePackagesDirPath /tmp/spm-cache",
    )

    upload_to_testflight(
      api_key:                         api_key,
      skip_waiting_for_build_processing: true,
      changelog:                       "PWA güncellendi — zoom ve platform iyileştirmeleri",
    )
  end

  # ── macOS (Mac Catalyst) → TestFlight ──────────────────────────────────────
  # Aynı Capacitor projesi macOS uygulamasına derlenir; Mac penceresi geniş
  # olduğu için otomatik PC PWA (desktop) layout gösterir. Apple Distribution
  # sertifikası iOS+macOS ortak; Mac App Store profilini Xcode otomatik üretir
  # (-allowProvisioningUpdates + ASC API key).
  lane :mac do
    api_key = app_store_connect_api_key(
      key_id:      ENV["ASC_KEY_ID"],
      issuer_id:   ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_PRIVATE_KEY"],
      in_house:    false,
    )

    build_app(
      project:          "ios/App/App.xcodeproj",
      scheme:           "App",
      configuration:    "Release",
      catalyst_platform: "macos",
      export_method:    "app-store",
      output_name:      "Hooder-mac.pkg",
      xcargs:           "-clonedSourcePackagesDirPath /tmp/spm-cache -allowProvisioningUpdates -authenticationKeyPath /tmp/asc_key.p8 -authenticationKeyID #{ENV['ASC_KEY_ID']} -authenticationKeyIssuerID #{ENV['ASC_ISSUER_ID']} SUPPORTS_MACCATALYST=YES",
      export_options: {
        teamID:       "SZF4T3P583",
        signingStyle: "automatic",
      },
    )

    upload_to_testflight(
      api_key:                           api_key,
      skip_waiting_for_build_processing: true,
      changelog:                         "macOS (Mac Catalyst) — PC PWA arayüzü",
    )
  end
end
